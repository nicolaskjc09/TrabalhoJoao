@page "/joao/contato"

<PageTitle>Contato - João</PageTitle>

<link rel="stylesheet" href="joao.css" />

<section class="pagina-historia">

    <div class="banner-principal">
        <p class="subtitulo-banner">Vamos nos conectar</p>
        <h1 class="titulo-banner">
            Entre em Contato
        </h1>

        <p class="texto-banner">
            Tenho interesse em oportunidades de colaboração, projetos interessantes e conversas sobre tecnologia e IA.
        </p>
    </div>

    <section class="conteudo-historia">

        <article class="cartao-destaque cartao-claro">
            <span class="numero-destaque">📧</span>

            <h2>Email</h2>

            <p>
                Entre em contato comigo via email para propostas de projeto, dúvidas ou apenas para conversar
                sobre tecnologia.
            </p>
        </article>

        <article class="cartao-destaque cartao-escuro">
            <span class="numero-destaque">💼</span>

            <h2>Redes Profissionais</h2>

            <p>
                Você pode me encontrar em redes profissionais como LinkedIn, GitHub e outras plataformas
                onde compartilho meus projetos.
            </p>
        </article>

        <article class="cartao-destaque cartao-destaque-contato">
            <span class="numero-destaque">💬</span>

            <h2>Redes Sociais</h2>

            <p>
                Também estou ativo em redes sociais onde compartilho sobre tecnologia, desenvolvimento
                e inteligência artificial.
            </p>
        </article>

    </section>

    <section class="secao-botoes-volta">
        <a href="/joao" class="botao-voltar">← Voltar para Portfólio</a>
    </section>

</section>
